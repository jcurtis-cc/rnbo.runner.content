                                    "rnbo_classname": "codebox",
                                    "rnbo_extra_attributes": {
                                        "hot": 0,
                                        "safemath": 1,
                                        "code": "@state notes: list = [];\r\n\r\nfunction in3(n) {\r\n    if (notes.includes(n)) {\r\n        notes.splice(notes.indexOf(n), 1);\r\n    }\r\n}\r\n\r\nfunction in2(n) {\r\n    if (!notes.includes(n)) {\r\n        notes.push(n);\r\n    }\r\n}\r\n\r\nif (notes.length > 0) {\r\n    let loff = notes.length * 8;\r\n    let idx = (in1 + loff) % notes.length;\r\n    let oct = floor((in1 + loff) / notes.length) - 8;\r\n    out1 = notes[idx] + 12 * oct;\r\n}",
                                        "nocache": 0
                                    },
