                                                                        "numoutlets": 1,
                                                                        "fontname": "<Monospaced>",
                                                                        "outlettype": [ "" ],
                                                                        "fontface": 0,
                                                                        "code": " // === RINGS PLUCKER ===                                                                     \n  //                                                                                                   \n  // INPUTS:                                                                                           \n  // in1 = trigger/click                                                                               \n  // in2 = frequency in Hz                                                                             \n  // in3 = brightness (0 to 1)                                                                         \n  // in4 = position (0 to 1)                                                                           \n                                                                                                       \n  Delay comb_del(256);                                                                                 \n                                                                                                       \n  History remaining_samples(0);                                                                        \n  History comb_period(0);                                                                              \n  History comb_gain(0);                                                                                \n  History svf_ic1eq(0);                                                                                \n  History svf_ic2eq(0);                                                                                \n                                                                                                       \n  sr = samplerate;                                                                                     \n                                                                                                       \n  trig = in1;                                                                                          \n  freq_hz = clamp(in2, 20, 4000);                                                                      \n  bright_in = clamp(in3, 0, 1);                                                                        \n  pos_in = clamp(in4, 0, 1);                                                                           \n                                                                                                       \n  // === CALCULATE EXCITER CUTOFF (from brightness) ===                                                \n  cutoff_shape = bright_in * (2 - bright_in);                                                          \n  exciter_cutoff = (freq_hz / sr) * pow(2, (cutoff_shape - 0.5) * 8);                                  \n  exciter_cutoff = clamp(exciter_cutoff * 8, 0.01, 0.499);                                             \n                                                                                                       \n  // === TRIGGER NEW BURST ===                                                                         \n  ratio = 0;                                                                                           \n  burst_length = 0;                                                                                    \n  comb_p = 0;                                                                                          \n  if (trig > 0.5) {                                                                                    \n      ratio = pos_in * 0.9 + 0.05;                                                                     \n      burst_length = (sr / freq_hz) * ratio;                                                           \n      remaining_samples = burst_length;                                                                \n                                                                                                       \n      comb_p = 1 / freq_hz * ratio * sr;                                                               \n      // Halve if too long                                                                             \n      comb_p = comb_p >= 255 ? comb_p * 0.5 : comb_p;                                                  \n      comb_p = comb_p >= 255 ? comb_p * 0.5 : comb_p;                                                  \n      comb_period = comb_p;                                                                            \n      comb_gain = (1 - pos_in) * 0.8;                                                                  \n  }                                                                                                    \n                                                                                                       \n  // === GENERATE NOISE BURST + COMB FILTER ===                                                        \n  noise_in = 0;                                                                                        \n  if (remaining_samples > 0) {                                                                         \n      noise_in = noise();                                                                              \n      remaining_samples = remaining_samples - 1;                                                       \n  }                                                                                                    \n                                                                                                       \n  comb_read = comb_del.read(comb_period, interp=\"linear\");                                             \n  exciter_out = noise_in + comb_gain * comb_read;                                                      \n  comb_del.write(exciter_out);                                                                         \n                                                                                                       \n  // === SVF LOWPASS ON EXCITER (brightness controls cutoff) ===                                       \n  svf_g = tan(PI * exciter_cutoff);                                                                    \n  svf_r = 1;  // Q = 1.0                                                                               \n  svf_h = 1 / (1 + svf_r * svf_g + svf_g * svf_g);                                                     \n                                                                                                       \n  hp = (exciter_out - svf_r * svf_ic1eq - svf_g * svf_ic1eq - svf_ic2eq) * svf_h;                      \n  bp = svf_g * hp + svf_ic1eq;                                                                         \n  svf_ic1eq = fixdenorm(svf_g * hp + bp);                                                              \n  lp = svf_g * bp + svf_ic2eq;                                                                         \n  svf_ic2eq = fixdenorm(svf_g * bp + lp);                                                              \n                                                                                                       \n  out1 = lp;     "
                                                                    }
