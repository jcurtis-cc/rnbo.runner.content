                                                                                                                  \n      poke(svf_shift_lut, 0.025013717, 44);                                                                                                                              \n      poke(svf_shift_lut, 0.023615102, 45);                                                                                                                              \n      poke(svf_shift_lut, 0.022294147, 46);                                                                                                                              \n      poke(svf_shift_lut, 0.021046624, 47);                                                                                                                              \n      poke(svf_shift_lut, 0.019868524, 48);                                                                                                                              \n      poke(svf_shift_lut, 0.018756046, 49);                                                                                                                              \n      poke(svf_shift_lut, 0.017705584, 50);                                                                                                                              \n      poke(svf_shift_lut, 0.016713725, 51);                                                                                                                              \n      poke(svf_shift_lut, 0.015777237, 52);                                                                                                                              \n      poke(svf_shift_lut, 0.014893059, 53);                                                                                                                              \n      poke(svf_shift_lut, 0.014058295, 54);                                                                                                                              \n      poke(svf_shift_lut, 0.013270204, 55);                                                                                                                              \n      poke(svf_shift_lut, 0.012526196, 56);                                                                                                                              \n      poke(svf_shift_lut, 0.011823821, 57);                                                                                                                              \n      poke(svf_shift_lut, 0.011160761, 58);                                                                                                                              \n      poke(svf_shift_lut, 0.010534826, 59);                                                                                                                              \n      poke(svf_shift_lut, 0.009943948, 60);                                                                                                                              \n      poke(svf_shift_lut, 0.009386170, 61);                                                                                                                              \n      poke(svf_shift_lut, 0.008859645, 62);                                                                                                                              \n      poke(svf_shift_lut, 0.008362627, 63);                                                                                                                              \n      poke(svf_shift_lut, 0.007893467, 64);                                                                                                                              \n      poke(svf_shift_lut, 0.007450607, 65);                                                                                                                              \n      poke(svf_shift_lut, 0.007032577, 66);                                                                               