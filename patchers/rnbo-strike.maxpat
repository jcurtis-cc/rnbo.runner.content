                                                                {
                                                                    "box": {
                                                                        "maxclass": "newobj",
                                                                        "text": "in 4 brightness",
                                                                        "patching_rect": [ 465.2, 64.0, 87.0, 22.0 ],
                                                                        "id": "obj-5",
