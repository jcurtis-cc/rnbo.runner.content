                                                    "numoutlets": 4,
                                                    "outlettype": [ "", "", "", "" ],
                                                    "patching_rect": [ 128.0, 100.0, 193.0, 23.0 ],
                                                    "rnbo_classname": "notein",
                                                    "rnbo_serial": 1,
                                                    "rnbo_uniqueid": "notein_obj-38",
                                                    "text": "notein"
                                                }
                                            },
                                            {
                                                "box": {
                                                    "genpatcher": {
                                                        "patcher": {
                                                            "fileversion": 1,
                                                            "appversion": {
                                                                "major": 9,
                                                                "minor": 1,
                                                                "revision": 1,
                                                                "architecture": "x64",
                                                                "modernui": 1
                                                            },
                                                            "classnamespace": "dsp.gen",
                                                            "rect": [ 41.0, 100.0, 1288.0, 1210.0 ],
                                                            "boxes": [
                                                                {
                                                                    "box": {
                                                                        "maxclass": "newobj",
                                                                        "text": "!- 1",
                                                                        "patching_rect": [ 349.8, 97.0, 26.0, 22.0 ],
                                                                        "id": "obj-30",
                                                                        "numinlets": 1,
                                                                        "numoutlets": 1,
                                                                        "outlettype": [ "" ]
                                                                    }
                                                                },
                                                                {
                                                                    "box": {
                                                                        "maxclass": "newobj",
                                                                        "text": "* 0.24",
                                                                        "patching_rect": [ 349.8, 124.0, 40.0, 22.0 ],
                                                                        "id": "obj-29",
                                                                        "numinlets": 1,
                                                                        "numoutlets": 1,
                                                                        "outlettype": [ "" ]
                                                                    }
                                                                },
                                                                {
                                                                    "box": {
                                                                        "maxclass": "codebox",
                                                                        "patching_rect": [ 785.0, 581.0, 340.0, 308.0 ],
                                                                        "id": "obj-14",
                                                                        "fontsize": 12.0,
                                                                        "numinlets": 1,
                                                                        "numoutlets": 0,
                                                                        "fontname": "<Monospaced>",
                                                                        "fontface": 0,
                                                                        "code": "// LUTChord table                                          \n  Data lut_s1(11, 1);                                                                                  \n  Data lut_s2(11, 1);                                                                                  \n  Data lut_s3(11, 1);                                                                                  \n                                                                                                       \n  // Initialize LUTs (intervals in semitones)                                                          \n  // Chord order: OCT, m7, m, m9, m11, 5th, M11, M9, M, M7, sus4                                       \n  poke(lut_s1, 0, 0, 0);     poke(lut_s2, 0.01, 0, 0);  poke(lut_s3, 12, 0, 0);    // OCT              \n  poke(lut_s1, 3, 1, 0);     poke(lut_s2, 7, 1, 0);     poke(lut_s3, 10, 1, 0);    // m7               \n  poke(lut_s1, 3, 2, 0);     poke(lut_s2, 7, 2, 0);     poke(lut_s3, 12, 2, 0);    // m                \n  poke(lut_s1, 3, 3, 0);     poke(lut_s2, 7, 3, 0);     poke(lut_s3, 14, 3, 0);    // m9               \n  poke(lut_s1, 3, 4, 0);     poke(lut_s2, 7, 4, 0);     poke(lut_s3, 17, 4, 0);    // m11              \n  poke(lut_s1, 7, 5, 0);     poke(lut_s2, 12, 5, 0);    poke(lut_s3, 19, 5, 0);    // 5th              \n  poke(lut_s1, 4, 6, 0);     poke(lut_s2, 7, 6, 0);     poke(lut_s3, 17, 6, 0);    // M11              \n  poke(lut_s1, 4, 7, 0);     poke(lut_s2, 7, 7, 0);     poke(lut_s3, 14, 7, 0);    // M9               \n  poke(lut_s1, 4, 8, 0);     poke(lut_s2, 7, 8, 0);     poke(lut_s3, 12, 8, 0);    // M                \n  poke(lut_s1, 4, 9, 0);     poke(lut_s2, 7, 9, 0);     poke(lut_s3, 11, 9, 0);    // M7               \n  poke(lut_s1, 5, 10, 0);    poke(lut_s2, 7, 10, 0);    poke(lut_s3, 12, 10, 0);   // sus4   "
                                                                    }
                                                                },
                                                                {
                                                                    "box": {
                                                                        "maxclass": "codebox",
                                                                        "patching_rect": [ 119.0, 576.0, 596.0, 419.0 ],
                                                                        "id": "obj-11",
                                                                        "fontsize": 12.0,
                                                                        "numinlets": 6,
                                                                        "numoutlets": 2,
                                                                        "fontname": "<Monospaced>",
                                                                        "outlettype": [ "", "" ],
                                                                        "fontface": 0,
                                                                        "code": "// === RINGS SYMPATHETIC STRINGS (3 voices) ===                                                      \n  //                                                                                                   \n  // INPUTS:                                                                                           \n  // in1 = audio from main string (feed main string's out1 - out2 here)                                \n  // in2 = base frequency in Hz (same as main string)                                                  \n  // in3 = structure (0 to 1, controls tuning spread)                                                  \n  // in4 = brightness (0 to 1)                                                                         \n  // in5 = damping (0 to 1)                                                                            \n  // in6 = position (0 to 1)        \r\n  \r\n  Data lut_s1(11, 1);                                                                                  \n  Data lut_s2(11, 1);                                                                                  \n  Data lut_s3(11, 1);                                                                       \n                                                                                                       \n  // === DELAY LINES (3 strings) ===                                                                   \n  Delay del1(2048);                                                                                    \n  Delay ap_del1(1024);                                                                                 \n  Delay del2(2048);                                                                                    \n  Delay ap_del2(1024);                                                                                 \n  Delay del3(2048);                                                                                    \n  Delay ap_del3(1024);                                                                                 \n                                                                                                       \n  // === HISTORIES STRING 1 ===                                                                        \n  History h_delay1(100);                                                                               \n  History h_pos1(0.5);                                                                                 \n  History h_disp1(0);                                                                                  \n  History fir_x1(0);                                                                                   \n  History fir_xx1(0);                                                                                  \n  History curved_bridge1(0);                                                                           \n  History dc_x1(0);                                                                                    \n  History dc_y1(0);                                                                                    \n  History svf_ic1eq1(0);                                                                               \n  History svf_ic2eq1(0);                                                                               \n  History lfo_phase1(0);                                                                               \n                                                                                                       \n  // === HISTORIES STRING 2 ===                                                                        \n  History h_delay2(100);                                                                               \n  History h_pos2(0.5);                                                                                 \n  History h_disp2(0);                                                                                  \n  History fir_x2(0);                                                                                   \n  History fir_xx2(0);                                                                                  \n  History curved_bridge2(0);                                                                           \n  History dc_x2(0);                                                                                    \n  History dc_y2(0);                                                                                    \n  History svf_ic1eq2(0);                                                                               \n  History svf_ic2eq2(0);                                                                               \n  History lfo_phase2(0);                                                                               \n                                                                                                       \n  // === HISTORIES STRING 3 ===                                                                        \n  History h_delay3(100);                                                                               \n  History h_pos3(0.5);                                                                                 \n  History h_disp3(0);                                                                                  \n  History fir_x3(0);                                                                                   \n  History fir_xx3(0);                                                                                  \n  History curved_bridge3(0);                                                                           \n  History dc_x3(0);                                                                                    \n  History dc_y3(0);                                                                                    \n  History svf_ic1eq3(0);                                                                               \n  History svf_ic2eq3(0);                                                                               \n  History lfo_phase3(0);                                                                                                                                                         \n                                                                                                       \n  sr = samplerate;                                                                                     \n                                                                                                       \n  // === INPUTS ===                                                                                    \n  audio_in_raw = in1;                                                                                  \n  base_freq = clamp(in2, 20, 4000);                                                                    \n  struct_in = clamp(in3, 0, 1);                                                                        \n  bright_in = clamp(in4, 0, 1);                                                                        \n  damp_in = clamp(in5, 0, 1);                                                                          \n  pos_in = clamp(in6, 0, 1);                                                                           \n                                                                                                       \n  // === SYMPATHETIC INPUT GAIN ===                                                                    \n  audio_in = audio_in_raw * 0.15;                                                                      \n                                                                                                       \n  // === SYMPATHETIC BRIGHTNESS (applied twice) ===                                                    \n  bright_symp = bright_in * (2 - bright_in);                                                           \n  bright_symp = bright_symp * (2 - bright_symp);                                                       \n  bright_sq = bright_symp * bright_symp;                                                               \n                                                                                                       \n  // === SYMPATHETIC DAMPING (restricted range + per-string increase) ===                              \n  damp_base = 0.7 + damp_in * 0.27;                                                                    \n                                                                                                       \n  // Per-string damping: higher strings get more damping toward 0.95                                   \n  // String indices: 1/4, 2/4, 3/4 (main string would be 0/4)                                          \n  damp_symp1 = damp_base + 0.25 * (0.95 - damp_base);                                                  \n  damp_symp2 = damp_base + 0.50 * (0.95 - damp_base);                                                  \n  damp_symp3 = damp_base + 0.75 * (0.95 - damp_base);                                                  \n                                                                                                       \n // Select chord (quantized to 11 steps)                                                              \n  chord_idx = floor(struct_in * 10.99);                                                                \n  chord_idx = clamp(chord_idx, 0, 10);                                                                 \n                                                                                                       \n  // Read intervals from LUTs                                                                          \n  interval1 = peek(lut_s1, chord_idx, 0);                                                              \n  interval2 = peek(lut_s2, chord_idx, 0);                                                              \n  interval3 = peek(lut_s3, chord_idx, 0);                                                              \n                                                                                                       \n  // Add slight detuning                                                                               \n  interval1 = interval1 + 0.013;                                                                       \n  interval2 = interval2 + 0.011;                                                                       \n  interval3 = interval3 + 0.007;                                                                       \n                                                                                                       \n  // === FREQUENCIES ===                                                                               \n  freq1 = base_freq * pow(2, interval1 / 12);                                                          \n  freq2 = base_freq * pow(2, interval2 / 12);                                                          \n  freq3 = base_freq * pow(2, interval3 / 12);                                                          \n                                                                                                       \n  freq1 = clamp(freq1, 20, 4000);                                                                      \n  freq2 = clamp(freq2, 20, 4000);                                                                      \n  freq3 = clamp(freq3, 20, 4000);                                                                       \n                                                                                                       \n                                                \n                                                                                                       \n  // Add slight detuning for chorus effect                                                             \n  interval1 = interval1 + 0.013;                                                                       \n  interval2 = interval2 + 0.011;                                                                       \n  interval3 = interval3 + 0.007;                                                                       \n                                                                                                       \n  // === FREQUENCIES ===                                                                               \n  freq1 = base_freq * pow(2, interval1 / 12);                                                          \n  freq2 = base_freq * pow(2, interval2 / 12);                                                          \n  freq3 = base_freq * pow(2, interval3 / 12);                                                          \n                                                                                                       \n  freq1 = clamp(freq1, 20, 4000);                                                                      \n  freq2 = clamp(freq2, 20, 4000);                                                                      \n  freq3 = clamp(freq3, 20, 4000);                                                                      \n                                                                                                       \n  // === DISPERSION (same mapping as main string) ===                                                  \n  dispersion = struct_in < 0.24                                                                        \n      ? (struct_in - 0.24) * 4.166                                                                     \n      : (struct_in > 0.26 ? (struct_in - 0.26) * 1.35135 : 0);                                         \n                                                                                                       \n  // === LFO FOR POSITION MODULATION ===                                                               \n  lfo_amount = (0.5 - abs(0.5 - pos_in)) * 0.9;                                                        \n                                                                                                       \n  lfo_phase1 = lfo_phase1 + 0.2 / sr;                                                                  \n  lfo_phase1 = lfo_phase1 - floor(lfo_phase1);                                                         \n  lfo1 = sin(lfo_phase1 * TWOPI);                                                                      \n  pos1 = pos_in + lfo1 * lfo_amount;                                                                   \n                                                                                                       \n  lfo_phase2 = lfo_phase2 + 0.17 / sr;                                                                 \n  lfo_phase2 = lfo_phase2 - floor(lfo_phase2);                                                         \n  lfo2 = sin(lfo_phase2 * TWOPI);                                                                      \n  pos2 = pos_in + lfo2 * lfo_amount;                                                                   \n                                                                                                       \n  lfo_phase3 = lfo_phase3 + 0.23 / sr;                                                                 \n  lfo_phase3 = lfo_phase3 - floor(lfo_phase3);                                                         \n  lfo3 = sin(lfo_phase3 * TWOPI);                                                                      \n  pos3 = pos_in + lfo3 * lfo_amount;                                                                   \n                                                                                                       \n  // === SHARED CALCULATIONS ===                                                                       \n  dc_coef = 1 - 20 / sr;                                                                               \n  fir_h0 = (1 + bright_sq) * 0.5;                                                                      \n  fir_h1 = (1 - bright_sq) * 0.25;                                                                     \n  svf_r = 2;                                                                                           \n                                                                                                       \n  // ============================================                                                      \n  // === STRING 1 ===                                                                                  \n  // ============================================                                                      \n  freq_norm1 = freq1 / sr;                                                                             \n  target_delay1 = sr / freq1;                                                                          \n  target_delay1 = clamp(target_delay1, 8, 2040);                                                       \n                                                                                                       \n  delay_now1 = h_delay1 + (target_delay1 - h_delay1) * 0.01;                                           \n  h_delay1 = fixdenorm(delay_now1);                                                                    \n                                                                                                       \n  clamped_pos1 = 0.5 - 0.98 * abs(pos1 - 0.5);                                                         \n  pos_now1 = h_pos1 + (clamped_pos1 - h_pos1) * 0.01;                                                  \n  h_pos1 = fixdenorm(pos_now1);                                                                        \n  comb_delay1 = max(delay_now1 * pos_now1, 4);                                                         \n                                                                                                       \n  disp_now1 = h_disp1 + (dispersion - h_disp1) * 0.01;                                                 \n  h_disp1 = fixdenorm(disp_now1);                                                                      \n                                                                                                       \n  // String 1 damping calculations                                                                     \n  lf_damping1 = damp_symp1 * (2 - damp_symp1);                                                         \n  rt60_base1 = 0.07 * pow(2, lf_damping1 * 8) * sr;                                                    \n  cutoff_raw1 = 24 + damp_symp1 * damp_symp1 * 48 + bright_sq * 24;                                    \n  damping_cutoff1 = min(cutoff_raw1, 84);                                                              \n  svf_shift1 = peek(svf_shift_lut, damping_cutoff1, 0, interp=\"linear\");                               \n  damping_comp1 = 1 - svf_shift1;                                                                      \n                                                                                                       \n  iir_freq1 = freq_norm1 * pow(2, damping_cutoff1 / 12);                                               \n  iir_freq1 = clamp(iir_freq1, 0.01, 0.499);                                                           \n                                                                                                       \n  rt60_ratio1 = -10 * delay_now1 / rt60_base1;                                                         \n  rt60_ratio1 = max(rt60_ratio1, -10.58);                                                              \n  damping_coeff1 = pow(2, rt60_ratio1);                                                                \n  damping_coeff1 = clamp(damping_coeff1, 0.0, 1.0);                                                    \n                                                                                                       \n  stretch_pt1 = disp_now1 > 0 ? disp_now1 * (2 - disp_now1) * 0.475 : 0;                               \n  bridge_cv_raw1 = disp_now1 < 0 ? -disp_now1 : 0;                                                     \n  ac_block_amt1 = bridge_cv_raw1;                                                                      \n  bridge_cv1 = bridge_cv_raw1 * bridge_cv_raw1 * 0.01;                                                 \n  ap_gain1 = disp_now1 > 0 ? -0.618 * disp_now1 / (0.15 + abs(disp_now1)) : 0;                         \n                                                                                                       \n  delay_fm1 = 1 - clamp(curved_bridge1, -5, 5) * bridge_cv1;                                           \n  del1_calc = delay_now1 * damping_comp1 - 1;                                                          \n  del1_calc = del1_calc * delay_fm1;                                                                   \n  del1_calc = clamp(del1_calc, 4, 2040);                                                               \n                                                                                                       \n  ap_d1 = del1_calc * stretch_pt1;                                                                     \n  main_d1 = del1_calc - ap_d1;                                                                         \n  main_d1 = max(main_d1, 4);                                                                           \n                                                                                                       \n  s1 = del1.read(main_d1, interp=\"spline\");                                                            \n                                                                                                       \n  ap_read1 = 0;                                                                                        \n  ap_write1 = 0;                                                                                       \n  ap_out1 = s1;                                                                                        \n  if (disp_now1 > 0.01 && ap_d1 >= 4 && main_d1 >= 4) {                                                \n      ap_read1 = ap_del1.read(ap_d1, interp=\"spline\");                                                 \n      ap_write1 = s1 + ap_gain1 * ap_read1;                                                            \n      ap_out1 = ap_read1 - ap_gain1 * ap_write1;                                                       \n      ap_del1.write(ap_write1);                                                                        \n      s1 = ap_out1;                                                                                    \n  }                                                                                                    \n                                                                                                       \n  s_ac1 = s1 - dc_x1 + dc_coef * dc_y1;                                                                \n  dc_x1 = fixdenorm(s1);                                                                               \n  dc_y1 = fixdenorm(s_ac1);                                                                            \n  s1 = s1 + ac_block_amt1 * (s_ac1 - s1);                                                              \n                                                                                                       \n  bval1 = abs(s1) - 0.025;                                                                             \n  bsign1 = s1 > 0 ? 1 : -1.5;                                                                          \n  new_bridge1 = (abs(bval1) + bval1) * bsign1;                                                         \n  curved_bridge1 = fixdenorm(disp_now1 < 0 ? clamp(new_bridge1, -5, 5) : 0);                           \n                                                                                                       \n  s1 = s1 + audio_in;                                                                                  \n                                                                                                       \n  fir_out1 = damping_coeff1 * (fir_h0 * fir_x1 + fir_h1 * (s1 + fir_xx1));                             \n  fir_xx1 = fixdenorm(fir_x1);                                                                         \n  fir_x1 = fixdenorm(s1);                                                                              \n  s1 = fir_out1;                                                                                       \n                                                                                                       \n  svf_g1 = tan(PI * iir_freq1);                                                                        \n  svf_h1_coef = 1 / (1 + svf_r * svf_g1 + svf_g1 * svf_g1);                                            \n                                                                                                       \n  hp1 = (s1 - svf_r * svf_ic1eq1 - svf_g1 * svf_ic1eq1 - svf_ic2eq1) * svf_h1_coef;                    \n  bp1 = svf_g1 * hp1 + svf_ic1eq1;                                                                     \n  svf_ic1eq1 = fixdenorm(svf_g1 * hp1 + bp1);                                                          \n  lp1 = svf_g1 * bp1 + svf_ic2eq1;                                                                     \n  svf_ic2eq1 = fixdenorm(svf_g1 * bp1 + lp1);                                                          \n                                                                                                       \n  s1 = lp1;                                                                                            \n  s1 = tanh(s1 * 0.5) * 2;                                                                             \n  del1.write(s1);                                                                                      \n                                                                                                       \n  out1_s1 = s1;                                                                                        \n  out2_s1 = del1.read(comb_delay1, interp=\"spline\");                                                   \n                                                                                                       \n  // ============================================                                                      \n  // === STRING 2 ===                                                                                  \n  // ============================================                                                      \n  freq_norm2 = freq2 / sr;                                                                             \n  target_delay2 = sr / freq2;                                                                          \n  target_delay2 = clamp(target_delay2, 8, 2040);                                                       \n                                                                                                       \n  delay_now2 = h_delay2 + (target_delay2 - h_delay2) * 0.01;                                           \n  h_delay2 = fixdenorm(delay_now2);                                                                    \n                                                                                                       \n  clamped_pos2 = 0.5 - 0.98 * abs(pos2 - 0.5);                                                         \n  pos_now2 = h_pos2 + (clamped_pos2 - h_pos2) * 0.01;                                                  \n  h_pos2 = fixdenorm(pos_now2);                                                                        \n  comb_delay2 = max(delay_now2 * pos_now2, 4);                                                         \n                                                                                                       \n  disp_now2 = h_disp2 + (dispersion - h_disp2) * 0.01;                                                 \n  h_disp2 = fixdenorm(disp_now2);                                                                      \n                                                                                                       \n  // String 2 damping calculations                                                                     \n  lf_damping2 = damp_symp2 * (2 - damp_symp2);                                                         \n  rt60_base2 = 0.07 * pow(2, lf_damping2 * 8) * sr;                                                    \n  cutoff_raw2 = 24 + damp_symp2 * damp_symp2 * 48 + bright_sq * 24;                                    \n  damping_cutoff2 = min(cutoff_raw2, 84);                                                              \n  svf_shift2 = peek(svf_shift_lut, damping_cutoff2, 0, interp=\"linear\");                               \n  damping_comp2 = 1 - svf_shift2;                                                                      \n                                                                                                       \n  iir_freq2 = freq_norm2 * pow(2, damping_cutoff2 / 12);                                               \n  iir_freq2 = clamp(iir_freq2, 0.01, 0.499);                                                           \n                                                                                                       \n  rt60_ratio2 = -10 * delay_now2 / rt60_base2;                                                         \n  rt60_ratio2 = max(rt60_ratio2, -10.58);                                                              \n  damping_coeff2 = pow(2, rt60_ratio2);                                                                \n  damping_coeff2 = clamp(damping_coeff2, 0.0, 1.0);                                                    \n                                                                                                       \n  stretch_pt2 = disp_now2 > 0 ? disp_now2 * (2 - disp_now2) * 0.475 : 0;                               \n  bridge_cv_raw2 = disp_now2 < 0 ? -disp_now2 : 0;                                                     \n  ac_block_amt2 = bridge_cv_raw2;                                                                      \n  bridge_cv2 = bridge_cv_raw2 * bridge_cv_raw2 * 0.01;                                                 \n  ap_gain2 = disp_now2 > 0 ? -0.618 * disp_now2 / (0.15 + abs(disp_now2)) : 0;                         \n                                                                                                       \n  delay_fm2 = 1 - clamp(curved_bridge2, -5, 5) * bridge_cv2;                                           \n  del2_calc = delay_now2 * damping_comp2 - 1;                                                          \n  del2_calc = del2_calc * delay_fm2;                                                                   \n  del2_calc = clamp(del2_calc, 4, 2040);                                                               \n                                                                                                       \n  ap_d2 = del2_calc * stretch_pt2;                                                                     \n  main_d2 = del2_calc - ap_d2;                                                                         \n  main_d2 = max(main_d2, 4);                                                                           \n                                                                                                       \n  s2 = del2.read(main_d2, interp=\"spline\");                                                            \n                                                                                                       \n  ap_read2 = 0;                                                                                        \n  ap_write2 = 0;                                                                                       \n  ap_out2 = s2;                                                                                        \n  if (disp_now2 > 0.01 && ap_d2 >= 4 && main_d2 >= 4) {                                                \n      ap_read2 = ap_del2.read(ap_d2, interp=\"spline\");                                                 \n      ap_write2 = s2 + ap_gain2 * ap_read2;                                                            \n      ap_out2 = ap_read2 - ap_gain2 * ap_write2;                                                       \n      ap_del2.write(ap_write2);                                                                        \n      s2 = ap_out2;                                                                                    \n  }                                                                                                    \n                                                                                                       \n  s_ac2 = s2 - dc_x2 + dc_coef * dc_y2;                                                                \n  dc_x2 = fixdenorm(s2);                                                                               \n  dc_y2 = fixdenorm(s_ac2);                                                                            \n  s2 = s2 + ac_block_amt2 * (s_ac2 - s2);                                                              \n                                                                                                       \n  bval2 = abs(s2) - 0.025;                                                                             \n  bsign2 = s2 > 0 ? 1 : -1.5;                                                                          \n  new_bridge2 = (abs(bval2) + bval2) * bsign2;                                                         \n  curved_bridge2 = fixdenorm(disp_now2 < 0 ? clamp(new_bridge2, -5, 5) : 0);                           \n                                                                                                       \n  s2 = s2 + audio_in;                                                                                  \n                                                                                                       \n  fir_out2 = damping_coeff2 * (fir_h0 * fir_x2 + fir_h1 * (s2 + fir_xx2));                             \n  fir_xx2 = fixdenorm(fir_x2);                                                                         \n  fir_x2 = fixdenorm(s2);                                                                              \n  s2 = fir_out2;                                                                                       \n                                                                                                       \n  svf_g2 = tan(PI * iir_freq2);                                                                        \n  svf_h2_coef = 1 / (1 + svf_r * svf_g2 + svf_g2 * svf_g2);                                            \n                                                                                                       \n  hp2 = (s2 - svf_r * svf_ic1eq2 - svf_g2 * svf_ic1eq2 - svf_ic2eq2) * svf_h2_coef;                    \n  bp2 = svf_g2 * hp2 + svf_ic1eq2;                                                                     \n  svf_ic1eq2 = fixdenorm(svf_g2 * hp2 + bp2);                                                          \n  lp2 = svf_g2 * bp2 + svf_ic2eq2;                                                                     \n  svf_ic2eq2 = fixdenorm(svf_g2 * bp2 + lp2);                                                          \n                                                                                                       \n  s2 = lp2;                                                                                            \n  s2 = tanh(s2 * 0.5) * 2;                                                                             \n  del2.write(s2);                                                                                      \n                                                                                                       \n  out1_s2 = s2;                                                                                        \n  out2_s2 = del2.read(comb_delay2, interp=\"spline\");                                                   \n                                                                                                       \n  // ============================================                                                      \n  // === STRING 3 ===                                                                                  \n  // ============================================                                                      \n  freq_norm3 = freq3 / sr;                                                                             \n  target_delay3 = sr / freq3;                                                                          \n  target_delay3 = clamp(target_delay3, 8, 2040);                                                       \n                                                                                                       \n  delay_now3 = h_delay3 + (target_delay3 - h_delay3) * 0.01;                                           \n  h_delay3 = fixdenorm(delay_now3);                                                                    \n                                                                                                       \n  clamped_pos3 = 0.5 - 0.98 * abs(pos3 - 0.5);                                                         \n  pos_now3 = h_pos3 + (clamped_pos3 - h_pos3) * 0.01;                                                  \n  h_pos3 = fixdenorm(pos_now3);                                                                        \n  comb_delay3 = max(delay_now3 * pos_now3, 4);                                                         \n                                                                                                       \n  disp_now3 = h_disp3 + (dispersion - h_disp3) * 0.01;                                                 \n  h_disp3 = fixdenorm(disp_now3);                                                                      \n                                                                                                       \n  // String 3 damping calculations                                                                     \n  lf_damping3 = damp_symp3 * (2 - damp_symp3);                                                         \n  rt60_base3 = 0.07 * pow(2, lf_damping3 * 8) * sr;                                                    \n  cutoff_raw3 = 24 + damp_symp3 * damp_symp3 * 48 + bright_sq * 24;                                    \n  damping_cutoff3 = min(cutoff_raw3, 84);                                                              \n  svf_shift3 = peek(svf_shift_lut, damping_cutoff3, 0, interp=\"linear\");                               \n  damping_comp3 = 1 - svf_shift3;                                                                      \n                                                                                                       \n  iir_freq3 = freq_norm3 * pow(2, damping_cutoff3 / 12);                                               \n  iir_freq3 = clamp(iir_freq3, 0.01, 0.499);                                                           \n                                                                                                       \n  rt60_ratio3 = -10 * delay_now3 / rt60_base3;                                                         \n  rt60_ratio3 = max(rt60_ratio3, -10.58);                                                              \n  damping_coeff3 = pow(2, rt60_ratio3);                                                                \n  damping_coeff3 = clamp(damping_coeff3, 0.0, 1.0);                                                    \n                                                                                                       \n  stretch_pt3 = disp_now3 > 0 ? disp_now3 * (2 - disp_now3) * 0.475 : 0;                               \n  bridge_cv_raw3 = disp_now3 < 0 ? -disp_now3 : 0;                                                     \n  ac_block_amt3 = bridge_cv_raw3;                                                                      \n  bridge_cv3 = bridge_cv_raw3 * bridge_cv_raw3 * 0.01;                                                 \n  ap_gain3 = disp_now3 > 0 ? -0.618 * disp_now3 / (0.15 + abs(disp_now3)) : 0;                         \n                                                                                                       \n  delay_fm3 = 1 - clamp(curved_bridge3, -5, 5) * bridge_cv3;                                           \n  del3_calc = delay_now3 * damping_comp3 - 1;                                                          \n  del3_calc = del3_calc * delay_fm3;                                                                   \n  del3_calc = clamp(del3_calc, 4, 2040);                                                               \n                                                                                                       \n  ap_d3 = del3_calc * stretch_pt3;                                                                     \n  main_d3 = del3_calc - ap_d3;                                                                         \n  main_d3 = max(main_d3, 4);                                                                           \n                                                                                                       \n  s3 = del3.read(main_d3, interp=\"spline\");                                                            \n                                                                                                       \n  ap_read3 = 0;                                                                                        \n  ap_write3 = 0;                                                                                       \n  ap_out3 = s3;                                                                                        \n  if (disp_now3 > 0.01 && ap_d3 >= 4 && main_d3 >= 4) {                                                \n      ap_read3 = ap_del3.read(ap_d3, interp=\"spline\");                                                 \n      ap_write3 = s3 + ap_gain3 * ap_read3;                                                            \n      ap_out3 = ap_read3 - ap_gain3 * ap_write3;                                                       \n      ap_del3.write(ap_write3);                                                                        \n      s3 = ap_out3;                                                                                    \n  }                                                                                                    \n                                                                                                       \n  s_ac3 = s3 - dc_x3 + dc_coef * dc_y3;                                                                \n  dc_x3 = fixdenorm(s3);                                                                               \n  dc_y3 = fixdenorm(s_ac3);                                                                            \n  s3 = s3 + ac_block_amt3 * (s_ac3 - s3);                                                              \n                                                                                                       \n  bval3 = abs(s3) - 0.025;                                                                             \n  bsign3 = s3 > 0 ? 1 : -1.5;                                                                          \n  new_bridge3 = (abs(bval3) + bval3) * bsign3;                                                         \n  curved_bridge3 = fixdenorm(disp_now3 < 0 ? clamp(new_bridge3, -5, 5) : 0);                           \n                                                                                                       \n  s3 = s3 + audio_in;                                                                                  \n                                                                                                       \n  fir_out3 = damping_coeff3 * (fir_h0 * fir_x3 + fir_h1 * (s3 + fir_xx3));                             \n  fir_xx3 = fixdenorm(fir_x3);                                                                         \n  fir_x3 = fixdenorm(s3);                                                                              \n  s3 = fir_out3;                                                                                       \n                                                                                                       \n  svf_g3 = tan(PI * iir_freq3);                                                                        \n  svf_h3_coef = 1 / (1 + svf_r * svf_g3 + svf_g3 * svf_g3);                                            \n                                                                                                       \n  hp3 = (s3 - svf_r * svf_ic1eq3 - svf_g3 * svf_ic1eq3 - svf_ic2eq3) * svf_h3_coef;                    \n  bp3 = svf_g3 * hp3 + svf_ic1eq3;                                                                     \n  svf_ic1eq3 = fixdenorm(svf_g3 * hp3 + bp3);                                                          \n  lp3 = svf_g3 * bp3 + svf_ic2eq3;                                                                     \n  svf_ic2eq3 = fixdenorm(svf_g3 * bp3 + lp3);                                                          \n                                                                                                       \n  s3 = lp3;                                                                                            \n  s3 = tanh(s3 * 0.5) * 2;                                                                             \n  del3.write(s3);                                                                                      \n                                                                                                       \n  out1_s3 = s3;                                                                                        \n  out2_s3 = del3.read(comb_delay3, interp=\"spline\");                                                   \n                                                                                                       \n  // ============================================                                                      \n  // === MIX OUTPUTS ===                                                                               \n  // ============================================                                                      \n  out1 = (out1_s1 + out1_s2 + out1_s3) * 0.5;                                                          \n  out2 = (out2_s1 + out2_s2 + out2_s3) * 0.5;  \r\n                                                          \n                                                                                                       \n  "
                                                                    }
                                                                },
