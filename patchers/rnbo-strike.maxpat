                                                                {
                                                                    "box": {
                                                                        "maxclass": "newobj",
                                                                        "text": "in 5 damping",
                                                                        "patching_rect": [ 580.6, 64.0, 77.0, 22.0 ],
                                                                        "id": "obj-6",
