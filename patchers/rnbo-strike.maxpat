                                                                {
                                                                    "box": {
                                                                        "maxclass": "newobj",
                                                                        "text": "in 2 frequency",
                                                                        "patching_rect": [ 234.4, 64.0, 84.0, 22.0 ],
                                                                        "id": "obj-2",
                                                                        "numinlets": 0,
                                                                        "numoutlets": 1,
                                                                        "outlettype": [ "" ]
                                                                    }
                                                                },
                                                                {
                                                                    "box": {
                                                                        "maxclass": "codebox",
                                                                        "patching_rect": [ 119.0, 164.0, 596.0, 396.0 ],
                                                                        "id": "obj-3",
                                                                        "fontsize": 12.0,
                                                                        "numinlets": 6,
                                                                        "numoutlets": 2,
                                                                        "fontname": "<Monospaced>",
                                                                        "outlettype": [ "", "" ],
                                                                        "fontface": 0,
                                                                        "code": "// === RINGS STRING MODEL ===                                                                        \n  //                                                                                                   \n  // INPUTS:                                                                                           \n  // in1 = audio input                                                                                 \n  // in2 = frequency in Hz (20-4000)                                                                   \n  // in3 = structure (0 to 0.25 for sympathetic mode)                                                     \n  // in4 = brightness (0 to 1)                                                                         \n  // in5 = damping (0 to 1)                                                                            \n  // in6 = position (0 to 1)                                                                           \n                                                                                                       \n  Delay main_del(2048);                                                                                \n  Delay ap_del(1024);                                                                                  \n                                                                                                       \n  History h_delay(100);                                                                                \n  History h_pos(0.5);                                                                                  \n  History h_disp(0);                                                                                   \n  History fir_x(0);                                                                                    \n  History fir_xx(0);                                                                                   \n  History curved_bridge(0);                                                                            \n  History dc_x(0);                                                                                     \n  History dc_y(0);                                                                                     \n  History svf_ic1eq(0);                                                                                \n  History svf_ic2eq(0);                                                                                \n  History dispersion_noise(0);                                                                         \n  History noise_lpf(0);                                                                                \n                                                                                                       \n  sr = samplerate;                                                                                     \n                                                                                                       \n  audio_in = in1;                                                                                      \n  freq_hz = clamp(in2, 20, 4000);                                                                      \n  disp_in = clamp(in3, 0, 1);  \r\n  bright_in = clamp(in4, 0, 1);                                                                        \n  damp_in = clamp(in5, 0, 1);                                                                          \n  pos_in = clamp(in6, 0, 1);                                                                           \n                                                                                                       \n  freq_norm = freq_hz / sr;                                                                            \n                                                                                                       \n  // === STRUCTURE TO DISPERSION MAPPING (with dead zone) ===                                          \n  // structure < 0.24: negative dispersion (sitar-like)                                                \n  // structure 0.24-0.26: no dispersion (dead zone)                                                    \n  // structure > 0.26: positive dispersion (inharmonic)                                                \n  //dispersion = 0; //= struct_in < 0.24                                                                        \n      //? (struct_in - 0.24) * 4.166                                                                     \n      //: (struct_in > 0.26 ? (struct_in - 0.26) * 1.35135 : 0);   \r\n                                                                         \n  dispersion = (disp_in - 0.24) * 4.166;                                        \n                                                                                                       \n  target_delay = sr / freq_hz;                                                                         \n  target_delay = clamp(target_delay, 8, 2040);                                                         \n                                                                                                       \n  delay_now = h_delay + (target_delay - h_delay) * 0.01;                                               \n  h_delay = fixdenorm(delay_now);                                                                      \n                                                                                                       \n  clamped_pos = 0.5 - 0.98 * abs(pos_in - 0.5);                                                        \n  pos_now = h_pos + (clamped_pos - h_pos) * 0.01;                                                      \n  h_pos = fixdenorm(pos_now);                                                                          \n  comb_delay = max(delay_now * pos_now, 4);                                                            \n                                                                                                       \n  disp_now = h_disp + (dispersion - h_disp) * 0.01;                                                    \n  h_disp = fixdenorm(disp_now);                                                                        \n                                                                                                       \n  bright_sq = bright_in * bright_in;                                                                   \n                                                                                                       \n  // === NOISE FILTER (from brightness) ===                                                            \n  noise_filter = pow(2, (bright_in - 1) * 4);                                                          \n                                                                                                       \n  cutoff_raw = 24 + damp_in * damp_in * 48 + bright_sq * 24;                                           \n  damping_cutoff = min(cutoff_raw, 84);                                                                \n                                                                                                       \n  // === IIR CUTOFF SCALES WITH FREQUENCY ===                                                          \n  iir_freq = freq_norm * pow(2, damping_cutoff / 12);                                                  \n  iir_freq = clamp(iir_freq, 0.01, 0.499);                                                             \n                                                                                                       \n  // === DAMPING COEFFICIENT (original formula) ===                                                    \n  lf_damping = damp_in * (2 - damp_in);                                                                \n  rt60_samples = 0.07 * pow(2, lf_damping * 8) * sr;                                                   \n  rt60_ratio = -10 * delay_now / rt60_samples;                                                         \n  rt60_ratio = max(rt60_ratio, -10.58);                                                                \n  damping_coeff = pow(2, rt60_ratio);                                                                  \n                                                                                                       \n  // === INFINITE SUSTAIN CROSSFADE (damping >= 0.95) ===                                              \n  to_inf = 0;                                                                                          \n  if (damp_in >= 0.95) {                                                                               \n      to_inf = 20 * (damp_in - 0.95);                                                                  \n  }                                                                                                    \n  damping_coeff = damping_coeff + to_inf * (1 - damping_coeff);                                        \n  bright_sq = bright_sq + to_inf * 0.7 * (1 - bright_sq);                                              \n  iir_freq = iir_freq + to_inf * (0.4999 - iir_freq);                                                  \n  damping_cutoff = damping_cutoff + to_inf * (128 - damping_cutoff);                                   \n                                                                                                       \n  // Final clamp                                                                                       \n  damping_coeff = clamp(damping_coeff, 0.0, 1.0);                                                      \n                                                                                                       \n  // === SVF SHIFT COMPENSATION (AFTER infinite sustain) ===                                           \n  svf_shift = peek(svf_shift_lut, damping_cutoff, 0, interp=\"linear\");                                 \n  damping_comp = 1 - svf_shift;                                                                        \n                                                                                                       \n  // === DISPERSION NOISE (for structure > 0.75, i.e. dispersion > ~0.66) ===                          \n  noise_raw = noise();                                                                                 \n  noise_raw = noise_raw / (0.2 + noise_filter);                                                        \n  dispersion_noise = dispersion_noise + noise_filter * (noise_raw - dispersion_noise);                 \n                                                                                                       \n  // Noise kicks in when dispersion > 0.66 (roughly structure > 0.75)                                  \n  noise_amount = disp_now > 0.66 ? 4 * (disp_now - 0.66) : 0;                                          \n  noise_amount = noise_amount * noise_amount * 0.025;                                                  \n                                                                                                       \n  // === TAME THE NOISE ===                                                                            \n  noise_lpf_coef = 0.1 + 0.9 / (1 + noise_amount * 20);                                                \n  noise_lpf = noise_lpf + noise_lpf_coef * (dispersion_noise - noise_lpf);                             \n  noise_lpf = fixdenorm(noise_lpf);                                                                    \n                                                                                                       \n  stretch_pt = disp_now > 0 ? disp_now * (2 - disp_now) * 0.475 : 0;                                   \n  bridge_cv_raw = disp_now < 0 ? -disp_now : 0;                                                        \n  ac_block_amt = bridge_cv_raw;                                                                        \n  bridge_cv = bridge_cv_raw * bridge_cv_raw * 0.01;                                                    \n  ap_gain = disp_now > 0 ? -0.618 * disp_now / (0.15 + abs(disp_now)) : 0;                             \n                                                                                                       \n  delay_fm = 1;                                                                                        \n  delay_fm = delay_fm + noise_lpf * noise_amount;                                                      \n  delay_fm = delay_fm - clamp(curved_bridge, -5, 5) * bridge_cv;                                       \n                                                                                                       \n  del = delay_now * damping_comp - 1;                                                                  \n  del = del * delay_fm;                                                                                \n  del = clamp(del, 4, 2040);                                                                           \n                                                                                                       \n  ap_d = del * stretch_pt;                                                                             \n  main_d = del - ap_d;                                                                                 \n  main_d = max(main_d, 4);                                                                             \n                                                                                                       \n  s = main_del.read(main_d, interp=\"spline\");                                                          \n                                                                                                       \n  if (disp_now > 0.01 && ap_d >= 4 && main_d >= 4) {                                                   \n      ap_read = ap_del.read(ap_d, interp=\"spline\");                                                    \n      ap_write = s + ap_gain * ap_read;                                                                \n      ap_out = ap_read - ap_gain * ap_write;                                                           \n      ap_del.write(ap_write);                                                                          \n      s = ap_out;                                                                                      \n  }                                                                                                    \n                                                                                                       \n  dc_coef = 1 - 20 / sr;                                                                               \n  s_ac = s - dc_x + dc_coef * dc_y;                                                                    \n  dc_x = fixdenorm(s);                                                                                 \n  dc_y = fixdenorm(s_ac);                                                                              \n  s = s + ac_block_amt * (s_ac - s);                                                                   \n                                                                                                       \n  bval = abs(s) - 0.025;                                                                               \n  bsign = s > 0 ? 1 : -1.5;                                                                            \n  new_bridge = (abs(bval) + bval) * bsign;                                                             \n  curved_bridge = fixdenorm(disp_now < 0 ? clamp(new_bridge, -5, 5) : 0);                              \n                                                                                                       \n  s = s + audio_in;                                                                                    \n                                                                                                       \n  fir_h0 = (1 + bright_sq) * 0.5;                                                                      \n  fir_h1 = (1 - bright_sq) * 0.25;                                                                     \n  fir_out = damping_coeff * (fir_h0 * fir_x + fir_h1 * (s + fir_xx));                                  \n  fir_xx = fixdenorm(fir_x);                                                                           \n  fir_x = fixdenorm(s);                                                                                \n  s = fir_out;                                                                                         \n                                                                                                       \n  // === 2-POLE SVF LOWPASS ===                                                                        \n  svf_g = tan(PI * iir_freq);                                                                          \n  svf_r = 2;                                                                                           \n  svf_h = 1 / (1 + svf_r * svf_g + svf_g * svf_g);                                                     \n                                                                                                       \n  hp = (s - svf_r * svf_ic1eq - svf_g * svf_ic1eq - svf_ic2eq) * svf_h;                                \n  bp = svf_g * hp + svf_ic1eq;                                                                         \n  svf_ic1eq = fixdenorm(svf_g * hp + bp);                                                              \n  lp = svf_g * bp + svf_ic2eq;                                                                         \n  svf_ic2eq = fixdenorm(svf_g * bp + lp);                                                              \n                                                                                                       \n  s = lp;                                                                                              \n                                                                                                       \n  s = tanh(s * 0.5) * 2;                                                                               \n                                                                                                       \n  main_del.write(s);                                                                                   \n                                                                                                       \n  out1 = s;                                                                                            \n  out2 = main_del.read(comb_delay, interp=\"spline\");  "
                                                                    }
                                                                },
