                                                                {
                                                                    "box": {
                                                                        "maxclass": "newobj",
                                                                        "text": "in 2 frequency",
                                                                        "patching_rect": [ 234.4, 64.0, 84.0, 22.0 ],
                                                                        "id": "obj-2",
                                                                        "numinlets": 0,
                                                                        "numoutlets": 1,
                                                                        "outlettype": [ "" ]
