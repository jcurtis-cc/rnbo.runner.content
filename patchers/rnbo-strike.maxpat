                                                                            "boxes": [
                                                                                {
                                                                                    "box": {
                                                                                        "maxclass": "newobj",
                                                                                        "text": "in trig",
                                                                                        "patching_rect": [ 50.0, 14.0, 38.0, 22.0 ],
                                                                                        "id": "obj-1",
                                                                                        "numinlets": 0,
                                                                                        "numoutlets": 1,
