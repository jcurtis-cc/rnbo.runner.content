                                                                        "code": "Data svf_shift_lut(257);                                                                                                                                               \n                                                                                                                                                                         \n  if (elapsed == 0) {                                                                                                                                                    \n      poke(svf_shift_lut, 0.250000000, 0);                                                                                                                               \n      poke(svf_shift_lut, 0.240811958, 1);                                                                                                                               \n      poke(svf_shift_lut, 0.231654461, 2);                                                                                                                               \n      poke(svf_shift_lut, 0.222557550, 3);                                                                                                                               \n      poke(svf_shift_lut, 0.213550276, 4);                                                                                                                               \n      poke(svf_shift_lut, 0.204660255, 5);                                                                                                                               \n      poke(svf_shift_lut, 0.195913276, 6);                                                                                                                               \n      poke(svf_shift_lut, 0.187332979, 7);                                                                                                                               \n      poke(svf_shift_lut, 0.178940603, 8);                                                                                                                               \n      poke(svf_shift_lut, 0.170754817, 9);                                                                                                                               \n      poke(svf_shift_lut, 0.162791623, 10);                                                                                                                              \n      poke(svf_shift_lut, 0.155064335, 11);                                                                                                                              \n      poke(svf_shift_lut, 0.147583618, 12);                                                                                                                              \n      poke(svf_shift_lut, 0.140357588, 13);                                                                                                                              \n      poke(svf_shift_lut, 0.133391951, 14);                                                                                                                              \n      poke(svf_shift_lut, 0.126690177, 15);                                                                                                                              \n      poke(svf_shift_lut, 0.120253700, 16);                                                                                                                              \n      poke(svf_shift_lut, 0.114082125, 17);                                                                                                                              \n      poke(svf_shift_lut, 0.108173448, 18);                                                                                                                              \n      poke(svf_shift_lut, 0.102524267, 19);                                                                                                                              \n      poke(svf_shift_lut, 0.097129992, 20);                                                                                                                              \n      poke(svf_shift_lut, 0.091985041, 21);                                                                                                                              \n      poke(svf_shift_lut, 0.087083020, 22);                                                                                                                              \n      poke(svf_shift_lut, 0.082416894, 23);                                                                                                                              \n      poke(svf_shift_lut, 0.077979130, 24);                                                                                                                              \n      poke(svf_shift_lut, 0.073761839, 25);                                                                                                                              \n      poke(svf_shift_lut, 0.069756882, 26);                                                                                                                              \n      poke(svf_shift_lut, 0.065955980, 27);                                                                                                                              \n      poke(svf_shift_lut, 0.062350797, 28);                                                                                                                              \n      poke(svf_shift_lut, 0.058933011, 29);                                                                                                                              \n      poke(svf_shift_lut, 0.055694377, 30);                                                                                                                              \n      poke(svf_shift_lut, 0.052626777, 31);                                                                