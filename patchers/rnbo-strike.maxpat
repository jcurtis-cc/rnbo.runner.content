                                                                        "fontface": 0,
                                                                        "code": "//============================================================================  \n// RINGS MODAL RESONATOR - 16 modes                             \n// Original (64 modes): Copyright 2015 Emilie Gillet (MIT License)                                  \n//============================================================================  \n                                                                                \n  Data lut_stiffness(257);                                                      \n  Data lut_4_decades(257);                                                      \n                                                                                \n  // Filter states (bp and lp for each mode)                                    \n  History bp0(0); History lp0(0);                                               \n  History bp1(0); History lp1(0);                                               \n  History bp2(0); History lp2(0);                                               \n  History bp3(0); History lp3(0);                                               \n  History bp4(0); History lp4(0);                                               \n  History bp5(0); History lp5(0);                                               \n  History bp6(0); History lp6(0);                                               \n  History bp7(0); History lp7(0);                                               \n  History bp8(0); History lp8(0);                                               \n  History bp9(0); History lp9(0);                                               \n  History bp10(0); History lp10(0);                                             \n  History bp11(0); History lp11(0);                                             \n  History bp12(0); History lp12(0);                                             \n  History bp13(0); History lp13(0);                                             \n  History bp14(0); History lp14(0);                                             \n  History bp15(0); History lp15(0);                                             \n                                                                                \n  History prev_pos(0.5);                                                        \n                                                                                \n  // INPUTS                                                                     \n  input = in1 * 0.125;                                                          \n                                                                                \n  freq = in2;                                                                   \n  freq = freq <= 0 ? 220/samplerate : freq;                                     \n  freq = clamp(freq, 0.001, 0.499);                                             \n                                                                                \n  structure = clamp(in3, 0, 1);                                                 \n  brightness = clamp(in4, 0, 1);                                                \n  damping = clamp(in5, 0, 1);                                                   \n  position = clamp(in6, 0, 1);                                                  \n                                                                                \n  prev_pos = prev_pos + 0.01 * (position - prev_pos);                           \n                                                                                \n  // ---- LUT INTERPOLATION for STIFFNESS ----                                  \n  stiff_idx = structure * 256;                                                  \n  stiff_i = trunc(stiff_idx);                                                   \n  stiff_f = stiff_idx - stiff_i;                                                \n  stiff_a = peek(lut_stiffness, stiff_i);                                       \n  stiff_b = peek(lut_stiffness, min(stiff_i + 1, 256));                         \n  stiffness = stiff_a + (stiff_b - stiff_a) * stiff_f;                          \n                                                                                \n  // ---- LUT INTERPOLATION for Q (4 decades) ----                              \n  q_idx = damping * 256;                                                        \n  q_i = trunc(q_idx);                                                           \n  q_f = q_idx - q_i;                                                            \n  q_a = peek(lut_4_decades, q_i);                                               \n  q_b = peek(lut_4_decades, min(q_i + 1, 256));                                 \n  q_base = 500 * (q_a + (q_b - q_a) * q_f);                                     \n                                                                                \n  // Brightness adjustments                                                     \n  bright_atten = 1 - structure;                                                 \n  bright_atten = bright_atten * bright_atten;                                   \n  bright_atten = bright_atten * bright_atten;                                   \n  bright_atten = bright_atten * bright_atten;                                   \n  bright_adj = brightness * (1 - 0.2 * bright_atten);                           \n  q_loss = bright_adj * (2 - bright_adj) * 0.85 + 0.15;                         \n  q_loss_rate = structure * (2 - structure) * 0.1;                              \n                                                                                \n  // Cosine oscillator (stable version)                                         \n  cos_iir = 2 * cos(TWOPI * prev_pos);                                          \n  cos_init = cos_iir * 0.25;                                                    \n                                                                                \n  // Initialize accumulators                                                    \n  odd = 0;                                                                      \n  even = 0;                                                                     \n  harmonic = freq;                                                              \n  stretch = 1;                                                                  \n  cur_q = q_base;                                                               \n  cur_stiff = stiffness;                                                        \n  cur_qloss = q_loss;                                                           \n  cy0 = 0.5;                                                                    \n  cy1 = cos_init;                                                               \n                                                                                \n  // MODE 0 (odd)                                                               \n  pf0 = min(harmonic * stretch, 0.49);                                          \n  g0 = tan(PI * pf0);                                                           \n  r0 = 1 / (1 + pf0 * cur_q);                                                   \n  h0 = 1 / (1 + r0 * g0 + g0 * g0);                                             \n  hp0 = (input - r0 * bp0 - lp0) * h0;                                          \n  v1_0 = g0 * hp0 + bp0;                                                        \n  bp0 = g0 * hp0 + v1_0;                                                        \n  v2_0 = g0 * bp0 + lp0;                                                        \n  lp0 = g0 * bp0 + v2_0;                                                        \n  bp0 = clamp(bp0, -4, 4);                                                      \n  lp0 = clamp(lp0, -4, 4);                                                      \n  amp0 = cy0; ct = cy0; cy0 = cos_iir * cy0 - cy1; cy1 = ct;                    \n  odd = odd + amp0 * v1_0;                                                      \n  stretch = stretch + cur_stiff;                                                \n  cur_stiff = cur_stiff * (cur_stiff < 0 ? 0.93 : 0.98);                        \n  cur_qloss = cur_qloss + q_loss_rate * (1 - cur_qloss);                        \n  harmonic = harmonic + freq;                                                   \n  cur_q = cur_q * cur_qloss;                                                    \n                                                                                \n  // MODE 1 (even)                                                              \n  pf1 = min(harmonic * stretch, 0.49);                                          \n  g1 = tan(PI * pf1);                                                           \n  r1 = 1 / (1 + pf1 * cur_q);                                                   \n  h1 = 1 / (1 + r1 * g1 + g1 * g1);                                             \n  hp1 = (input - r1 * bp1 - lp1) * h1;                                          \n  v1_1 = g1 * hp1 + bp1;                                                        \n  bp1 = g1 * hp1 + v1_1;                                                        \n  v2_1 = g1 * bp1 + lp1;                                                        \n  lp1 = g1 * bp1 + v2_1;                                                        \n  bp1 = clamp(bp1, -4, 4);                                                      \n  lp1 = clamp(lp1, -4, 4);                                                      \n  amp1 = cy0; ct = cy0; cy0 = cos_iir * cy0 - cy1; cy1 = ct;                    \n  even = even + amp1 * v1_1;                                                    \n  stretch = stretch + cur_stiff;                                                \n  cur_stiff = cur_stiff * (cur_stiff < 0 ? 0.93 : 0.98);                        \n  cur_qloss = cur_qloss + q_loss_rate * (1 - cur_qloss);                        \n  harmonic = harmonic + freq;                                                   \n  cur_q = cur_q * cur_qloss;                                                    \n                                                                                \n  // MODE 2 (odd)                                                               \n  pf2 = min(harmonic * stretch, 0.49);                                          \n  g2 = tan(PI * pf2);                                                           \n  r2 = 1 / (1 + pf2 * cur_q);                                                   \n  h2 = 1 / (1 + r2 * g2 + g2 * g2);                                             \n  hp2 = (input - r2 * bp2 - lp2) * h2;                                          \n  v1_2 = g2 * hp2 + bp2;                                                        \n  bp2 = g2 * hp2 + v1_2;                                                        \n  v2_2 = g2 * bp2 + lp2;                                                        \n  lp2 = g2 * bp2 + v2_2;                                                        \n  bp2 = clamp(bp2, -4, 4);                                                      \n  lp2 = clamp(lp2, -4, 4);                                                      \n  amp2 = cy0; ct = cy0; cy0 = cos_iir * cy0 - cy1; cy1 = ct;                    \n  odd = odd + amp2 * v1_2;                                                      \n  stretch = stretch + cur_stiff;                                                \n  cur_stiff = cur_stiff * (cur_stiff < 0 ? 0.93 : 0.98);                        \n  cur_qloss = cur_qloss + q_loss_rate * (1 - cur_qloss);                        \n  harmonic = harmonic + freq;                                                   \n  cur_q = cur_q * cur_qloss;                                                    \n                                                                                \n  // MODE 3 (even)                                                              \n  pf3 = min(harmonic * stretch, 0.49);                                          \n  g3 = tan(PI * pf3);                                                           \n  r3 = 1 / (1 + pf3 * cur_q);                                                   \n  h3 = 1 / (1 + r3 * g3 + g3 * g3);                                             \n  hp3 = (input - r3 * bp3 - lp3) * h3;                                          \n  v1_3 = g3 * hp3 + bp3;                                                        \n  bp3 = g3 * hp3 + v1_3;                                                        \n  v2_3 = g3 * bp3 + lp3;                                                        \n  lp3 = g3 * bp3 + v2_3;                                                        \n  bp3 = clamp(bp3, -4, 4);                                                      \n  lp3 = clamp(lp3, -4, 4);                                                      \n  amp3 = cy0; ct = cy0; cy0 = cos_iir * cy0 - cy1; cy1 = ct;                    \n  even = even + amp3 * v1_3;                                                    \n  stretch = stretch + cur_stiff;                                                \n  cur_stiff = cur_stiff * (cur_stiff < 0 ? 0.93 : 0.98);                        \n  cur_qloss = cur_qloss + q_loss_rate * (1 - cur_qloss);                        \n  harmonic = harmonic + freq;                                                   \n  cur_q = cur_q * cur_qloss;                                                    \n                                                                                \n  // MODE 4 (odd)                                                               \n  pf4 = min(harmonic * stretch, 0.49);                                          \n  g4 = tan(PI * pf4);                                                           \n  r4 = 1 / (1 + pf4 * cur_q);                                                   \n  h4 = 1 / (1 + r4 * g4 + g4 * g4);                                             \n  hp4 = (input - r4 * bp4 - lp4) * h4;                                          \n  v1_4 = g4 * hp4 + bp4;                                                        \n  bp4 = g4 * hp4 + v1_4;                                                        \n  v2_4 = g4 * bp4 + lp4;                                                        \n  lp4 = g4 * bp4 + v2_4;                                                        \n  bp4 = clamp(bp4, -4, 4);                                                      \n  lp4 = clamp(lp4, -4, 4);                                                      \n  amp4 = cy0; ct = cy0; cy0 = cos_iir * cy0 - cy1; cy1 = ct;                    \n  odd = odd + amp4 * v1_4;                                                      \n  stretch = stretch + cur_stiff;                                                \n  cur_stiff = cur_stiff * (cur_stiff < 0 ? 0.93 : 0.98);                        \n  cur_qloss = cur_qloss + q_loss_rate * (1 - cur_qloss);                        \n  harmonic = harmonic + freq;                                                   \n  cur_q = cur_q * cur_qloss;                                                    \n                                                                                \n  // MODE 5 (even)                                                              \n  pf5 = min(harmonic * stretch, 0.49);                                          \n  g5 = tan(PI * pf5);                                                           \n  r5 = 1 / (1 + pf5 * cur_q);                                                   \n  h5 = 1 / (1 + r5 * g5 + g5 * g5);                                             \n  hp5 = (input - r5 * bp5 - lp5) * h5;                                          \n  v1_5 = g5 * hp5 + bp5;                                                        \n  bp5 = g5 * hp5 + v1_5;                                                        \n  v2_5 = g5 * bp5 + lp5;                                                        \n  lp5 = g5 * bp5 + v2_5;                                                        \n  bp5 = clamp(bp5, -4, 4);                                                      \n  lp5 = clamp(lp5, -4, 4);                                                      \n  amp5 