, 			{
				"box" : 				{
					"code" : "History invRate,cachedSize,cachedRate,invMs,invSams,relativeVariation;\n\nHistory randomVariation,scanPositionL,scanPositionR,\n\tpositionNote,smoothedModPos,scanKeyFollow;\n\nParam pFileSR(44100);\nParam pFileSamps;\nParam pPositionSmooth,pSmooth;\n\nParam pPosition(0.5);\nParam pScanLoopOn(0);\nParam pScanKeyOn(0);\nParam pScanRate(0);\nParam pScanDistance(0);\n\nParam pGlobalVariation,pVariationToPosition,pKeyToPosition,pVelToPosition,\n\tpNotePressToPosition,pNoteSlideToPosition,pNotePBToPosition,\n\tpRandToPosition,pLFOToPosition,pEnv2ToPosition;\n\nParam pVelToScan,pSlideToScan,pEnv2ToScan,pLFOToScan;\n\nParam pRelativeKey,pRelativeVelocity,pNotePress,pNoteSlide,pNotePB;\n\ntrigger = in1;\nLFOL = in2;\nLFOR = in3;\nenv2 = in4;\nvariationL = in5;\nvariationR = in6;\n\nnoiseGen = abs(noise());\n\nif (pFileSamps != cachedSize || samplerate != cachedRate){\n\tcachedSize = pFileSamps;\n\tcachedRate = samplerate;\n\n\tinvRate = pFileSR / samplerate;\n\tlengthMs = 1000 * (pFileSamps / samplerate);\n\tinvMs = 1 / lengthMs;\n\tinvSams = 1 / pFileSamps;\n\tinvMtof = 1 / mtof(0); // here to prevent another branching\n}\n\nif (pGlobalVariation != 0 || pVariationToPosition != 0){\n\trelativeVariation = (pGlobalVariation * pVariationToPosition) * invMs; \n\trelativeVariation = relativeVariation * invRate;\n}\n\n//  --- Scan --- we calculate key and vel pos mod here since they only update on note on. \n// ...which is not the case in modo, where we support legato.\nif (trigger){\n\tscanPositionL = 0;  \n\tscanPositionR = 0;  \n\tpositionNote = (1 + pRelativeVelocity) * pVelToPosition + \n\t\tmtof(pRelativeKey * pKeyToPosition) * invMtof + \n\t\tnoise() * pRandToPosition;\n\n\tscanKeyFollow = mtof(pRelativeKey * pScanKeyOn) * invMtof;\n}\n\n// ---- position ----\nmodPos = pPosition + \n\tpNotePress * pNotePressToPosition +\n\tpNoteSlide * pNoteSlideToPosition +\n\tpNotePBToPosition * pNotePB;\n\npSmoothX = pSmooth * (1 - trigger);\nsmoothedModPos = modPos * (1 - pSmoothX) + pSmoothX * smoothedModPos;\npositionMono =  positionNote + smoothedModPos + env2 * pEnv2ToPosition;\n\npositionL =  positionMono + \n\tLFOL * pLFOToPosition + \n\tnoiseGen * variationL * relativeVariation;\n\npositionR =  positionMono + LFOR * pLFOToPosition + \n\tnoiseGen * variationR * relativeVariation;\n\ncScanRate = pScanRate * invRate;\n\nvelModScan =  pRelativeVelocity * pVelToScan + (1 - pVelToScan);\nenvModScan = env2 * pEnv2ToScan + (1 - pEnv2ToScan);\nslideModScan = pNoteSlide * pSlideToScan + (1 - pSlideToScan);\nnormScan = (velModScan * envModScan * slideModScan) * cScanRate * invSams;\n\nnormScanRateL = normScan * (1 + (LFOL * pLFOToScan));\nnormScanRateR = normScan * (1 + (LFOR * pLFOToScan));\n\nscanRateL =  normScanRateL * scanKeyFollow;\nscanRateR =  normScanRateR * scanKeyFollow;\n\nif (pScanLoopOn >0){\n\tscanPositionL = mod(scanPositionL + scanRateL, pScanDistance);\n\tscanPositionR = mod(scanPositionR + scanRateR, pScanDistance);\n} else {\n\tscanPositionL = clip(scanPositionL + scanRateL, 0, pScanDistance);\n\tscanPositionR = clip(scanPositionR + scanRateR, 0, pScanDistance);\n}\n\nout1 = mod(1 + positionL + scanPositionL, 1);\nout2 = mod(1 + positionR + scanPositionR, 1);",
					"fontface" : 0,
					"fontname" : "<Monospaced>",
					"fontsize" : 12.0,
					"id" : "obj-3",
					"maxclass" : "codebox",
