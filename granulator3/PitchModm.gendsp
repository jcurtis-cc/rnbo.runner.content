, 			{
				"box" : 				{
					"code" : "History randomVariation,outL,outR,\n\tinvMtof, relativePitchL, relativePitchR,\n\toutL,outR;\n\nParam pTranspose,pSpread,pTune,pTimeMode;\n\n// ------ MIDI & MPE ------\nParam pNotePress,pNoteSlide,pNotePB;\n\n// --- Modulations ---\nParam pKeyToPitch,pNotePressAmount,pNotePBAmount,\n\tpEnv2ToPitch,pLFOToPitch,pRandomToPitch;\n\nParam pVelToSpread,pPressToSpread,pSlideToSpread,\n\tpEnv2ToSpread,pLFOToSpread;\n\n// --- signal inputs ---\ntrigger = in1;\nLFOL = in2;\nLFOR = in3;\nenv2 = in4;\nrpRelativeKey = in5;\nrpRelativeVelocity = in6;\n\nif (invMtof == 0){\n\tinvMtof = 1 / mtof(0);\n\t}\n\n// --- NoteOn ---\nif (trigger){\n\trandomVariation = noise();\n\t}\n\n// --- spread ---\nenvSpreadMod = 1 - ((1 - env2) * pEnv2ToSpread);\nvelSpreadMod = envSpreadMod  * 1 - ((1 - rpRelativeVelocity) * pVelToSpread);\npressSpreadMod = velSpreadMod * 1 - ((1 - pNotePress) * pPressToSpread);\nslideSpreadMod = pressSpreadMod * 1 - ((1 - pNoteSlide) * pSlideToSpread);\n\nLFOSpreadModL = 1 + LFOL * pLFOToSpread;\nLFOSpreadModR = 1 + LFOR * pLFOToSpread;\nspreadModL = slideSpreadMod * LFOSpreadModL;\nspreadModR = slideSpreadMod * LFOSpreadModR;\n\n// --- Pitch Modulation\nkeyPitchMod = rpRelativeKey * pKeyToPitch;\nmpePitchMod = pNotePB * pNotePBAmount + pNotePress * pNotePressAmount;\nrandPitchMod = randomVariation * pRandomToPitch;\nenvPitchMod = env2 * pEnv2ToPitch;\npitchScaled = pTranspose + pTune + keyPitchMod + mpePitchMod + randPitchMod + envPitchMod;\n\n// --- stereo modulators  ---\nif (pTimeMode < 2){\n\trelativePitchL = pitchScaled + pLFOToPitch * LFOL - pSpread * spreadModL;\n\trelativePitchR = pitchScaled + pLFOToPitch * LFOR + pSpread * spreadModR;\n\toutL = mtof(relativePitchL) * invMtof;\n\toutR = mtof(relativePitchR) * invMtof;\n} else {\n\tpitchFactorL = mtof(pitchScaled - pSpread * spreadModL) * invMtof;\n\tpitchFactorR = mtof(pitchScaled + pSpread * spreadModR) * invMtof;\n\tfmModL = pLFOToPitch * LFOL;\n\tfmModR = pLFOToPitch * LFOR;\n\n\toutL = pitchFactorL + fmModL * invMtof;\n\toutR = pitchFactorR + fmModR * invMtof;\n}\n\nout1 = outL;\nout2 = outR;\n",
					"fontface" : 0,
					"fontname" : "<Monospaced>",
					"fontsize" : 12.0,
