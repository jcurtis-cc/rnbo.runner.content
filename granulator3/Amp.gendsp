				"box" : 				{
					"code" : "History pressMod,slideMod;\n\nParam pLevel(-12);\n\n// ------ MIDI & MPE ------\nParam pRelativeKey,pRelativeVelocity,\n\tpNotePress,pNoteSlide,pNotePB;\n\n// --- Modulations ---\nParam pKeyToAmp,pVelocityToAmp,\n    pPressToAmp,pSlideToAmp,\n    pLFOToAmp;\n\n// --- inputs ---\ninL = in1;\ninR = in2;\nenv1 = in3;\nLFOL = in4;\nLFOR = in5;\n\nif (pPressToAmp > 0) {\n\tpressMod = 1 - ((1 - pNotePress) * pPressToAmp);\n} else {\n\tpressMod = 1 - (pNotePress * (-pPressToAmp));\n}\n\nif (pSlideToAmp > 0) {\n\tslideMod = 1 - ((1 - pNoteSlide) * pSlideToAmp);\n} else {\n\tslideMod = 1 - (pNoteSlide * (-pSlideToAmp));\n}\n\nmpeMod = pressMod * slideMod;\n\nlfoModL = LFOL * pLFOToAmp;\nlfoModR = LFOR * pLFOToAmp;\n\nampL = dbtoa(pLevel + pVelocityToAmp * pRelativeVelocity +\n\tpRelativeKey * pKeyToAmp - lfoModL + (pLFOToAmp * 0.062));\n\nampR = dbtoa(pLevel + pVelocityToAmp * pRelativeVelocity +\n\tpRelativeKey * pKeyToAmp - lfoModR + (pLFOToAmp * 0.062));\n\nout1 = inL * env1 * mpeMod * ampL;\nout2 = inR * env1 * mpeMod * ampR;\n",
					"fontface" : 0,
					"fontname" : "<Monospaced>",
					"fontsize" : 12.0,
