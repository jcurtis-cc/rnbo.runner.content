, 			{
				"box" : 				{
					"code" : "Buffer SoundFile();\nBuffer RTGViz();\n\nHistory invRate,cachedSize,cachedRate,invMs,invSams,relativeVariation;\n\nHistory randomVariation,scanPositionL,scanPositionR,\n\tpositionNote,smoothedModPos,scanKeyFollow;\n\nParam pFileSR(44100);\nParam pSmooth;\n\nParam pPosition(0.5);\nParam pScanLoopOn(0);\nParam pScanKeyOn(0);\nParam pScanRate(0);\nParam pScanDistance(0);\n\nParam pGlobalVariation,pVariationToPosition,pKeyToPosition,pVelToPosition,\n\tpNotePressToPosition,pNoteSlideToPosition,pNotePBToPosition,\n\tpRandToPosition,pLFOToPosition,pEnv2ToPosition;\n\nParam pVelToScan,pSlideToScan,pEnv2ToScan,pLFOToScan;\n\nParam pNotePress,pNoteSlide,pNotePB;\n\n// --- signal inputs ---\ntrigger = in1;\nLFOL = in2;\nLFOR = in3;\nenv2 = in4;\nvariationL = in5;\nvariationR = in6;\nrpRelativeKey = in7;\nrpRelativeVelocity = in8;\n\nfileSizeSamps = dim(SoundFile);\nnoiseGen = abs(noise());\n\nif (fileSizeSamps != cachedSize || samplerate != cachedRate){\n\tcachedSize = fileSizeSamps;\n\tcachedRate = samplerate;\n\n\tinvRate = pFileSR / samplerate;\n\tlengthMs = 1000 * (fileSizeSamps / samplerate);\n\tinvMs = 1 / lengthMs;\n\tinvSams = 1 / fileSizeSamps;\n\tinvMtof = 1 / mtof(0); // here to prevent another branching\n}\n\nif (pGlobalVariation != 0 || pVariationToPosition != 0){\n\trelativeVariation = (pGlobalVariation * pVariationToPosition) * invMs; \n\trelativeVariation = relativeVariation * invRate;\n}\n\nscanKeyFollow = mtof(rpRelativeKey * pScanKeyOn) * invMtof;\n\npositionNote = (1 + rpRelativeVelocity) * pVelToPosition + \n\tmtof(rpRelativeKey * pKeyToPosition) * invMtof + noise() * pRandToPosition;\n\n//  --- Scan ---\nif (trigger > 0){\n\tscanPositionL = 0;  \n\tscanPositionR = 0;  \n}\n\n// ---- position ----\nmodPos = pPosition + \n\tpNotePress * pNotePressToPosition +\n\tpNoteSlide * pNoteSlideToPosition +\n\tpNotePBToPosition * pNotePB;\n\npSmoothX = pSmooth * (1 - trigger);\nsmoothedModPos = modPos * (1 - pSmoothX) + pSmoothX * smoothedModPos;\npositionMono =  positionNote + smoothedModPos + env2 * pEnv2ToPosition;\n\npositionL =  positionMono + \n\tLFOL * pLFOToPosition + \n\tnoiseGen * variationL * relativeVariation;\n\npositionR =  positionMono + LFOR * pLFOToPosition + \n\tnoiseGen * variationR * relativeVariation;\n\ncScanRate = pScanRate * invRate;\n\nvelModScan =  rpRelativeVelocity * pVelToScan + (1 - pVelToScan);\nenvModScan = env2 * pEnv2ToScan + (1 - pEnv2ToScan);\nslideModScan = pNoteSlide * pSlideToScan + (1 - pSlideToScan);\nnormScan = (velModScan * envModScan * slideModScan) * cScanRate * invSams;\n\nnormScanRateL = normScan * (1 + (LFOL * pLFOToScan));\nnormScanRateR = normScan * (1 + (LFOR * pLFOToScan));\n\nscanRateL =  normScanRateL * scanKeyFollow;\nscanRateR =  normScanRateR * scanKeyFollow;\n\nif (pScanLoopOn >0){\n\tscanPositionL = mod(scanPositionL + scanRateL, pScanDistance);\n\tscanPositionR = mod(scanPositionR + scanRateR, pScanDistance);\n} else {\n\tscanPositionL = clip(scanPositionL + scanRateL, 0, pScanDistance);\n\tscanPositionR = clip(scanPositionR + scanRateR, 0, pScanDistance);\n}\n\nout1 = mod(1 + positionL + scanPositionL, 1);\nout2 = mod(1 + positionR + scanPositionR, 1);",
					"fontface" : 0,
					"fontname" : "<Monospaced>",
					"fontsize" : 12.0,
					"id" : "obj-3",
					"maxclass" : "codebox",
