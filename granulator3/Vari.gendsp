, 			{
				"box" : 				{
					"code" : "// ------ Parameters ------\nParam pVariation();\n\nParam pRelativeKey,pRelativeVelocity,pNotePress,pNoteSlide;\n\nParam pKeyToVariation,pVelToVariation,pPressToVariation,pSlideToVariation,\n    pLFOToVariation,pEnv2ToVariation;\n\n// --- modulation source signals ---\nLFOL = in1;\nLFOR = in2;\nenv2 = clip(in3 * 1.1 - 0.1, 0, 1);\n\nkeyMod = ((pKeyToVariation * ((pRelativeKey+64)*0.015))) + (1 - pKeyToVariation);\nvelMod = ((pVelToVariation * pRelativeVelocity)) + (1 - pVelToVariation);\r\n\r\nenvFix = (pEnv2ToVariation < 0);\r\nenvMod = 1 - ((1 - env2) * pEnv2ToVariation) + (pEnv2ToVariation*envFix); //fixed gen env\n\r\npressMod = (pNotePress * pPressToVariation) + (1 - pPressToVariation);\nslideMod = (pNoteSlide * pSlideToVariation) + (1 - pSlideToVariation);\n\nmonoVariation =  pVariation * keyMod * velMod * pressMod * slideMod * envMod;\nvarLFOModL = ((1 + LFOL) * pLFOToVariation) + (1 - pLFOToVariation);\nvarLFOModR = ((1 + LFOR) * pLFOToVariation) + (1 - pLFOToVariation);\n\nvarL = monoVariation * varLFOModL;\nvarR = monoVariation * varLFOModR;\n\nout1 = clip(varL, 0, 1);\nout2 = clip(varR, 0, 1);\n",
					"fontface" : 0,
					"fontname" : "<Monospaced>",
					"fontsize" : 12.0,
