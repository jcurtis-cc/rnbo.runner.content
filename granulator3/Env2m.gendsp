, 			{
				"box" : 				{
					"code" : "//--- internal registers ---\nHistory currentGain,isAttackFlag;\n\nHistory cachedAttack,cachedDecay,cachedRelease,\n\tattackScaled,decayScaled,releaseScaled,\n\tcachedScaling;\n\nHistory rateScaling(1);\n\nParam pAttack(10); // linear ramp in miliseconds, independent of sample rate\nParam pDecay(1000); // log ramp in milliseconds, independent off sam\nParam pSustain(0);\nParam pRelease(600);\nParam pKeyToRates(0); // scales all evelope rates relative to C3\n\n// ------ MIDI & MPE ------\nParam pNotePress(0);\nParam pNoteSlide(0);\nParam pNotePB(0);\n\npGate = in1; // is 1 as long as note runs\npTrigger = in2; // single sample 1 pulse at note start\nrpRelativeKey = in3;\n\nsrScaled = samplerate * 0.001;\n\nenvScaling = rpRelativeKey * pKeyToRates;\n\nif (envScaling != cachedScaling || pAttack != cachedAttack || pDecay != cachedDecay || pRelease != cachedRelease){\n\tcachedScaling = envScaling;\n\tcachedAttack = pAttack;\n\tcachedDecay = pDecay;\n\tcachedRelease = pRelease;\n\t\n\trateScaling = mtof(envScaling) / mtof(0);\n\n\tinvAttack = 1 / (pAttack * srScaled);\n\tattackRate  = invAttack;\n\tattackScaled = rateScaling * attackRate;\n\t\n    invDecay = 1 / (pDecay * srScaled);\n\tdecayRate   = (1 - pow(0.001, invDecay));\n\tdecayScaled = rateScaling * decayRate;\n\t\n    invRelease = 1 / (pRelease * srScaled);\n\treleaseRate = (1 - pow(0.001, invRelease));\n\treleaseScaled = rateScaling * releaseRate;\n}\n\n// --- release rate switch --- disabled for Env 2\nreleaseScaledSwitch = releaseScaled;// * ( 1 + 1 * (currentGain < 0.001));\n\n// note on\nif (pTrigger > 0){\n\tisAttackFlag = 1;\n\t// only set current gain if it is small, allowing for retrigger\n\tif (currentGain <= 0.001) {\n    currentGain  = (pAttack < 0.11); // if Attack time is very fast, we start at 1, else from 0\n  }\n}\n\n// attack phase\nif \t((isAttackFlag > 0) && (pGate > 0)){\n\t// linear ramp up\t\n\tcurrentGain = currentGain + attackScaled;\n\t// end attack\n\tif (currentGain > 1){\n\t\tisAttackFlag = 0;\n\t\tcurrentGain  = 1;\n\t}\n} else {\n\t// decay release level/rate switch\t\n\ttargetGain = pSustain * pGate;\n\trate = releaseScaledSwitch * (1 - pGate) + decayScaled * pGate;\n\tdeltaGain = (currentGain - targetGain);\n\t// exponential ramp up\n\tcurrentGain = currentGain - deltaGain * rate;\n}\n\nout1 = \tcurrentGain; \n",
					"fontface" : 0,
					"fontname" : "<Monospaced>",
					"fontsize" : 12.0,
